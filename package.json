{
  "name": "workspace-app",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop-first, local-first communications workspace",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm --filter @workspace/desktop dev",
    "dev:ui": "pnpm --filter @workspace/ui dev",
    "build": "pnpm -r build",
    "package:desktop": "pnpm --filter @workspace/desktop package",
    "release:desktop": "pnpm --filter @workspace/desktop release",
    "verify:data-paths": "pnpm --filter @workspace/desktop verify:data-paths",
    "test:migrations": "pnpm --filter @workspace/db build && node ./scripts/test-migrations.js",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.8.3"
  }
}
