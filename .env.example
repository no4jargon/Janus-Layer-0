# Janus Layer 0 (desktop)

# Runtime mode
NODE_ENV=development

# Local LLM (optional)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# Gmail OAuth (required for Gmail connector)
# IMPORTANT: register this redirect URI in your Google OAuth app.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:43123/oauth/google/callback

# Update feed override (optional)
# The app defaults to the GitHub Releases `latest.json` for this repo.
# Set this only to point installed clients at a different feed (e.g. staging).
# JANUS_UPDATE_FEED_URL=https://github.com/no4jargon/Janus-Layer-0/releases/latest/download/latest.json

# Forced-update threshold (release-time only; read by apps/desktop/electron/package.js)
# Lowest version still allowed to run. Anyone below it gets the full-window
# Required Update screen on next launch; anyone between it and the new version
# gets the optional sidebar banner.
# Defaults to the new release's version, which means EVERY prior version is
# forced to update on every release. Set this LOWER than the new version when
# you want a release to be optional (cosmetic fix, non-breaking feature, etc.).
# MIN_SUPPORTED_VERSION=0.1.0
