{
  "name": "chai",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node ./electron/dev.js",
    "build": "node ./electron/build.js",
    "package": "node ./electron/package.js",
    "release": "cross-env CHAI_RELEASE=1 node ./electron/package.js",
    "verify:data-paths": "node ./electron/verify-data-paths.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chai/ai": "workspace:*",
    "@chai/connectors-gmail": "workspace:*",
    "@chai/connectors-whatsapp": "workspace:*",
    "@chai/core": "workspace:*",
    "@chai/db": "workspace:*",
    "@chai/shared": "workspace:*",
    "@node-llama-cpp/linux-arm64": "3.18.1",
    "@node-llama-cpp/linux-armv7l": "3.18.1",
    "@node-llama-cpp/linux-x64": "3.18.1",
    "@node-llama-cpp/linux-x64-cuda": "3.18.1",
    "@node-llama-cpp/linux-x64-vulkan": "3.18.1",
    "@node-llama-cpp/mac-arm64-metal": "3.18.1",
    "@node-llama-cpp/mac-x64": "3.18.1",
    "@node-llama-cpp/win-arm64": "3.18.1",
    "@node-llama-cpp/win-x64": "3.18.1",
    "@node-llama-cpp/win-x64-cuda": "3.18.1",
    "@node-llama-cpp/win-x64-vulkan": "3.18.1",
    "baileys": "^7.0.0-rc.9",
    "electron-updater": "^6.6.2",
    "node-llama-cpp": "3.18.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.chai.app",
    "productName": "Chai",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-llama-cpp/**",
      "**/node_modules/@node-llama-cpp/**"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "no4jargon",
      "repo": "Janus-Layer-0",
      "releaseType": "draft"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network"
    }
  }
}
