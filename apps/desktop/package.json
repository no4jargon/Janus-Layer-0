{
  "name": "@workspace/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node ./electron/dev.js",
    "build": "node ./electron/build.js",
    "package": "node ./electron/package.js",
    "release": "WORKSPACE_RELEASE=1 node ./electron/package.js",
    "verify:data-paths": "node ./electron/verify-data-paths.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/ai": "workspace:*",
    "@workspace/connectors-gmail": "workspace:*",
    "@workspace/connectors-whatsapp": "workspace:*",
    "@workspace/core": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/shared": "workspace:*",
    "baileys": "^7.0.0-rc.9",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.workspace.app",
    "productName": "Workspace App",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "no4jargon",
      "repo": "Janus-Layer-0"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network"
    }
  }
}
